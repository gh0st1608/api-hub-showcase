{
  "name": "api-service-nestjs",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "docs": "tsc-watch --onSuccess \"node dist/scripts/serve-docs.js\"",
    "migration:generate": "tsc && typeorm migration:generate -d dist/src/infrastructure/database/migration.datasource.js",
    "migration:run": "tsc && typeorm migration:run -d dist/src/infrastructure/database/migration.datasource.js",
    "migration:revert": "tsc && typeorm migration:revert -d dist/src/infrastructure/database/migration.datasource.js",
    "start": "node dist/src/main.js",
    "test": "jest",
    "test:cov": "jest --coverage",
    "sonar": "node run-sonar.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --ext .ts --fix",
      "tsc --noEmit --skipLibCheck"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/client-sns": "^3.1054.0",
    "@aws-sdk/lib-dynamodb": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "0.217.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cloudevents": "^10.0.0",
    "jose": "^6.2.3",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "newrelic": "^13.19.2",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sonar-scanner": "^3.1.0",
    "typeorm": "^0.3.29",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "tsc-watch": "^7.2.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
