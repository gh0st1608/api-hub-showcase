{
    "name": "api-claim",
    "version": "1.0.0",
    "dependencies": {
        "@redocly/openapi-cli": "0.12.16"
    },
    "private": true,
    "scripts": {
        "start": "openapi preview-docs --port 8084 openapi/openapi.yaml",
        "build": "openapi bundle -o dist/claim-cargocom.yaml",
        "build-html": "redoc-cli bundle ./dist/claim-cargocom.yaml --output ./dist/claim-cargocom.html -t ./docs/index.html",
        "test": "openapi validate"
    },
    "devDependencies": {
        "@redocly/openapi-cli": "0.12.7",
        "redoc-cli": "^0.13.21"
    }
}