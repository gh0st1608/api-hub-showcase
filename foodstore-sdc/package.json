{
    "name": "api-foodstore",
    "version": "1.0.0",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.914.0",
        "@redocly/openapi-cli": "0.12.16",
        "dotenv": "^17.2.3"
    },
    "private": true,
    "scripts": {
        "start": "openapi preview-docs --port 8084 openapi/openapi.yaml",
        "build": "openapi bundle -o dist/foodstore-sdc.yaml",
        "build-html": "redoc-cli bundle ./dist/foodstore-sdc.yaml --output ./dist/foodstore-sdc.html -t ./docs/index.html",
        "test": "openapi validate"
    },
    "devDependencies": {
        "@redocly/openapi-cli": "0.12.7",
        "redoc-cli": "^0.13.21"
    }
}
