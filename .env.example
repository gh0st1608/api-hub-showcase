PORT=3000
NODE_ENV=development

OTEL_SERVICE_NAME=api-service
OTEL_SERVICE_NAMESPACE=backend
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRIC_EXPORT_INTERVAL=10000
NEW_RELIC_APP_NAME=api-service-nestjs
NEW_RELIC_LICENSE_KEY=

PROJECT_REPOSITORY_DRIVER=memory
FILE_STORAGE_DRIVER=local

DB_HOST=localhost
DB_PORT=5432
DB_USER=appuser
DB_PASSWORD=appsecret
DB_NAME=appdb

DYNAMO_ENDPOINT=http://localhost:8000
PROJECTS_TABLE_NAME=Projects

AUTH_ENABLED=false
JWT_ISSUER=http://localhost:8080/realms/dev
JWT_AUDIENCE=api-service
JWKS_URI=http://localhost:8080/realms/dev/protocol/openid-connect/certs
JWT_ALGORITHMS=RS256
JWT_ROLES_CLAIM=realm_access.roles
JWT_SCOPE_CLAIM=scope

OPA_ENABLED=false
OPA_URL=http://localhost:8181
OPA_POLICY_PACKAGE=samples/allow
OPA_DECISION_TIMEOUT_MS=500
OPA_FAIL_OPEN=false

EVENT_BUS=sns
AWS_REGION=us-east-1
AWS_SNS_ENDPOINT=http://localhost:4566
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:my-topic
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_FORCE_PATH_STYLE=false

SERVICE_NAME=api-service-nestjs
