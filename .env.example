VITE_APP_NAME="API Hub Showcase"

# Catalog source. Local dev can use /manifest.json from public/.
# Production can point to your CloudFront URL, e.g.:
# VITE_MANIFEST_URL="https://cdn.tudominio.com/manifest.json"
# VITE_MANIFEST_URL="/manifest.json"

# LOCAL DEV: leave empty to use Vite proxy (avoids CORS). Backend must run on port 3001.
# VITE_API_BASE_URL=

# PRODUCTION / DOCKER: set the full backend URL.
# VITE_API_BASE_URL="https://api.your-domain.com"
